<Window x:Class="AmpClean.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:AmpClean.Presentation.ViewModels"
        xmlns:views="clr-namespace:AmpClean.Presentation.Views"
        Title="AMP Clean Architecture" Height="780" Width="1280"
        MinHeight="680" MinWidth="1080" WindowStartupLocation="CenterScreen"
        Background="#F4F6FA" Loaded="OnLoaded">
    <Window.Resources>
        <!-- ViewModel 到 View 的映射让导航不需要在代码隐藏中创建页面。 -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:MeasureViewModel}"><views:MeasureView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigsViewModel}"><views:ConfigsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PathsViewModel}"><views:PathsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#172038">
            <Grid Margin="20,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="12" Background="#6750A4">
                        <materialDesign:PackIcon Kind="ChartBellCurveCumulative" Foreground="White"
                                                 Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,2,0,0">
                        <TextBlock Text="AMP" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Clean Architecture" Foreground="#AEB7CC" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="业务模块" Foreground="#7F8AA6" Margin="4,36,0,12"
                           FontSize="12" FontWeight="SemiBold" />

                <ItemsControl Grid.Row="2" ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Key}" Height="48" Margin="0,0,0,8"
                                    HorizontalContentAlignment="Left" Background="Transparent" Foreground="#DCE2F2"
                                    BorderThickness="0" Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding Icon}" Width="22" Height="22" />
                                    <TextBlock Text="{Binding Title}" Margin="16,0,0,0" FontSize="14" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="3" Background="#202B48" CornerRadius="12" Padding="14">
                    <StackPanel>
                        <TextBlock Text="架构状态" Foreground="#AEB7CC" FontSize="11" />
                        <TextBlock Text="Domain ← Application" Foreground="White" Margin="0,6,0,0" />
                        <TextBlock Text="Infrastructure · WPF" Foreground="#AEB7CC" FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Background="White" BorderBrush="#E5E8F0" BorderThickness="0,0,0,1">
                <Grid Margin="30,0">
                    <TextBlock Text="{Binding CurrentTitle}" FontSize="24" FontWeight="SemiBold"
                               Foreground="#1D2433" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#E8F5E9" CornerRadius="12" Padding="10,5">
                            <TextBlock Text="● 系统就绪" Foreground="#247A3D" FontSize="12" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" Margin="30,26" />
        </Grid>
    </Grid>
</Window>
