<UserControl x:Class="AmpClean.Presentation.Views.ConfigsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="3*" /><ColumnDefinition Width="20" /><ColumnDefinition Width="2*" /></Grid.ColumnDefinitions>
        <materialDesign:Card Padding="18">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="配置列表" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Command="{Binding NewCommand}" Content="新增配置" HorizontalAlignment="Right"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                </Grid>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedConfig}"
                          AutoGenerateColumns="False" IsReadOnly="True" Margin="0,18,0,0"
                          CanUserAddRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="仪器类型" Binding="{Binding InstrumentType}" Width="150" />
                        <DataGridTextColumn Header="型号" Binding="{Binding DeviceModel}" Width="150" />
                        <DataGridTextColumn Header="次数" Binding="{Binding RepeatCount}" Width="70" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="2" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="配置详情" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="配置名称" Margin="0,0,0,16" />
                    <ComboBox ItemsSource="{Binding InstrumentTypes}" SelectedItem="{Binding InstrumentType}"
                              materialDesign:HintAssist.Hint="仪器类型" Margin="0,0,0,16" />
                    <TextBox Text="{Binding DeviceModel, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="设备型号" Margin="0,0,0,16" />
                    <TextBox Text="{Binding MotionPathName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="运动路径名称" Margin="0,0,0,16" />
                    <TextBox Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="重复次数（1-100）" Margin="0,0,0,20" />
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SaveCommand}" Content="保存" Width="100"
                                Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,12,0" />
                        <Button Command="{Binding DeleteCommand}" Content="删除" Width="90"
                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                    </StackPanel>
                    <Border Background="#F3F0FA" CornerRadius="8" Padding="12" Margin="0,22,0,0">
                        <TextBlock Text="{Binding Message}" Foreground="#51466F" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>
    </Grid>
</UserControl>
