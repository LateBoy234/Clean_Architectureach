<UserControl x:Class="AmpClean.Presentation.Views.MeasureView"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer>
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <GroupBox Header="测量数据" Grid.Column="0" Margin="10">
                    <Border>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="色转序号" HorizontalAlignment="Center" Margin="2,0,2,0"/>
                                <TextBlock Text="测量数据" Grid.Column="1" HorizontalAlignment="Center" Margin="2,0,2,0"/>
                            </Grid>
                            <ListBox Grid.Row="1" ItemsSource="{Binding MeasurementData}" ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto" MinHeight="400" MinWidth="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <!--显示行号-->
                                            <TextBlock Text="{Binding Index}" HorizontalAlignment="Center" Margin="2,0,2,0"/> 
                                            <!--每行显示8个数据项-->
                                            <ItemsControl ItemsSource="{Binding MeasurementItems}" Grid.Column="1" Background="{Binding RemindColor}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate> 
                                                        <UniformGrid Columns="8" Margin="2"/> 
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat=F2}" HorizontalAlignment="Center" Padding="2,0,2,0"/> 
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                        </Grid>
                    </Border>
                </GroupBox>
                <GroupBox Header="计算数据" Grid.Column="1" Margin="10">
                </GroupBox>
                <GroupBox Header="仪器数据" Grid.Column="2" Margin="10">
                </GroupBox>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <GroupBox Header="操作" Grid.Column="0" Margin="10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 5">
                            <Button Margin="5" Height="32" Width="100" Content="自动测量" Command="{Binding AutoMeasureCommand}"/>
                            <Button Margin="5" Height="32" Width="100" Content="继续测量" Command="{Binding ContinueMeasureCommand}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Margin="5" Height="32" Width="100" Content="停止测量" Command="{Binding StopMeasureCommand}"/>
                            <Button Margin="5" Height="32" Width="100" Content="回到原点" Command="{Binding ReturnToOriginCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="路径信息" Grid.Column="1" Margin="10">
                    <StackPanel>

                    </StackPanel>
                </GroupBox>
                <GroupBox Header="平台控制" Grid.Column="2" Margin="10">
                    <StackPanel>

                    </StackPanel>
                </GroupBox>
            </Grid>
        </Grid>
        
    </ScrollViewer>
</UserControl>
