<UserControl x:Class="AmpClean.Presentation.Views.MeasureView"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
              xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer>
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <GroupBox Header="测量数据" Grid.Column="0" Margin="10">
                    <Border>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="色转序号" HorizontalAlignment="Center" Margin="2,0,2,0"/>
                                <TextBlock Text="测量数据" Grid.Column="1" HorizontalAlignment="Center" Margin="2,0,2,0"/>
                            </Grid>
                            <ListBox Grid.Row="1" ItemsSource="{Binding MeasurementData}" ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto" MinHeight="400" MinWidth="220">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <!--显示行号-->
                                            <TextBlock Text="{Binding Index}" HorizontalAlignment="Center" Margin="2,0,2,0"/> 
                                            <!--每行显示8个数据项-->
                                            <ItemsControl ItemsSource="{Binding MeasurementItems}" Grid.Column="1" Background="{Binding RemindColor}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate> 
                                                        <UniformGrid Columns="8" Margin="2"/> 
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat=F2}" HorizontalAlignment="Center" Padding="2,0,2,0"/> 
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                        </Grid>
                    </Border>
                </GroupBox>
                <GroupBox Header="计算数据" Grid.Column="1" Margin="10">
                    <Border  CornerRadius="3" BorderThickness="1" BorderBrush="LightBlue">
                        <ListBox ItemsSource="{Binding ResultDataList}" MaxHeight="600" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <!-- 设置横向排列的 WrapPanel -->
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="{Binding ResultColsNumber}" Margin="2"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0 2 0 2"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#EEE" Margin="2">
                                        <TextBlock Text="{Binding StringFormat=F2}" HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </GroupBox>
                <GroupBox Header="仪器数据" Grid.Column="2" Margin="10">
                    <Border  CornerRadius="3" BorderThickness="1" BorderBrush="LightBlue">
                        <ListBox ItemsSource="{Binding ReadDataList, Mode=TwoWay}" MaxHeight="600" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <!-- 设置横向排列的 WrapPanel -->
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="{Binding ColsNumber}"  Margin="2"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0 2 0 2"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#EEE" Margin="2">
                                        <TextBlock Text="{Binding StringFormat=F2}" HorizontalAlignment="Center" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <GroupBox Header="操作" Grid.Column="0" Margin="10">
                    <StackPanel>
                        <!-- 页面打开后自动读取校准矩阵并执行 RLS，此处展示结果或错误。 -->
                        <TextBlock Text="{Binding CalibrationStatus}" Margin="5,5,5,10"
                                   TextWrapping="Wrap" Foreground="DarkSlateBlue" />
                        <StackPanel Orientation="Horizontal" Margin="0 5">
                            <Button Margin="5" Height="32" Width="100" Content="自动测量" Command="{Binding AutoMeasureCommand}"/>
                            <Button Margin="5" Height="32" Width="100" Content="继续测量" Command="{Binding ContinueMeasureCommand}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Margin="5" Height="32" Width="100" Content="停止测量" Command="{Binding StopMeasureCommand}"/>
                            <Button Margin="5" Height="32" Width="100" Content="回到原点" Command="{Binding ReturnToOriginCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="路径信息" Grid.Column="1" Margin="10">
                    <DataGrid  x:Name="PointlistDatagrid"
                         ItemsSource="{Binding Points}"  Height="230" 
                         SelectedItem="{Binding SelectedPoint}"
                         VerticalScrollBarVisibility="Auto"
                         GridLinesVisibility="All"
                         VerticalAlignment="Stretch"
                         AutoGenerateColumns="False"
                         CanUserDeleteRows="False"
                         CanUserSortColumns="False"
                         CanUserAddRows="False"
                         SelectionMode="Single"
                         SelectionUnit="FullRow"
                         IsReadOnly="True">
                        <DataGrid.RowHeaderStyle>
                            <Style TargetType="{x:Type DataGridRowHeader}">
                                <Setter Property="Content" Value="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
                            </Style>
                        </DataGrid.RowHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"  Binding="{Binding Index}" Width="50"/>
                            <DataGridTextColumn Header="X" Binding="{Binding X, StringFormat=F0}"  Width="60" />
                            <DataGridTextColumn Header="Y"  Binding="{Binding Y, StringFormat=F0}"  Width="60" />
                            <DataGridTextColumn Header="Z" Binding="{Binding Z, StringFormat=F0}"  Width="60" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
                <GroupBox Header="平台控制" Grid.Column="2" Margin="10">
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Y-" Grid.Row="0" Grid.Column="1" ToolTip="Y轴负向运动" Margin="5">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding YAxisNegativeMoveCommand}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding AllAxisStopMoveCommand}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <Button Content="X+"  Grid.Row="1" Grid.Column="0" 
                                 ToolTip="Y轴正向运动" Margin="5">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding XAxisPositiveMoveCommand}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding AllAxisStopMoveCommand}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <Button Content="急停"  Grid.Row="1" Grid.Column="1"  Background="Red"
                               ToolTip="Y轴正向运动" Command="{Binding EStopCommand}" Margin="5">

                        </Button>
                        <Button Content="X-" Grid.Row="1" Grid.Column="2" Margin="5"
                                 ToolTip="X轴负向运动">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding XAxisNegativeMoveCommand}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding AllAxisStopMoveCommand}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <Button Content="X0" Grid.Row="2" Grid.Column="0" Margin="5"
                                 ToolTip="X轴正向运动"
                                Command="{Binding  XGoZeroCommand}"
                                >

                        </Button>
                        <Button Content="Y0" Grid.Row="2" Margin="5"
                                Grid.Column="2" 
                                 ToolTip="Y轴回原点" Command="{Binding  YGoZeroCommand}" >

                        </Button>
                        <Button Content="Y+" Grid.Row="2" Grid.Column="1" Margin="5"
                                ToolTip="Y轴正向运动">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding YAxisPositiveMoveCommand}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding AllAxisStopMoveCommand}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <Button Content="Z+" Grid.Row="3" Grid.Column="2" Margin="5"
                                ToolTip="Z轴正向运动">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding ZAxisPositiveMoveCommand}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding AllAxisStopMoveCommand}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <Button Content="Z-" Grid.Row="3" Grid.Column="0" Margin="5" ToolTip="Z轴负向运动">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding ZAxisNegativeMoveCommand}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding AllAxisStopMoveCommand}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>
                        <Button Content="Z0" Grid.Row="3" Grid.Column="1" Margin="5"
                                 ToolTip="Z轴回原点" Command="{Binding  ZGoZeroCommand}">

                        </Button>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>
        
    </ScrollViewer>
</UserControl>
