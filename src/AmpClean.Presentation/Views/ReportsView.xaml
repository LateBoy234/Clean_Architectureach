<UserControl x:Class="AmpClean.Presentation.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <materialDesign:Card Padding="22">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <StackPanel><TextBlock Text="测量报告" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="展示 AMP 报告管理模块对应的查询边界。" Foreground="#6B7280" Margin="0,5,0,16" /></StackPanel>
            <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="报告编号" Binding="{Binding ReportNo}" Width="2*" />
                    <DataGridTextColumn Header="配置" Binding="{Binding ConfigName}" Width="2*" />
                    <DataGridTextColumn Header="被测设备" Binding="{Binding DeviceName}" Width="2*" />
                    <DataGridTextColumn Header="ΔE" Binding="{Binding DeltaE, StringFormat=F3}" Width="100" />
                    <DataGridCheckBoxColumn Header="合格" Binding="{Binding IsQualified}" Width="90" />
                    <DataGridTextColumn Header="测量时间(UTC)" Binding="{Binding MeasuredAtUtc, StringFormat=yyyy-MM-dd HH:mm}" Width="170" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </materialDesign:Card>
</UserControl>
