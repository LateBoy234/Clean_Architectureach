<UserControl x:Class="AmpClean.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="设备运行与业务数据概览" Foreground="#6B7280" FontSize="14" Margin="0,0,0,22" />
            <UniformGrid Columns="3" Margin="0,0,0,22">
                <materialDesign:Card Margin="0,0,14,0" Padding="22">
                    <StackPanel><materialDesign:PackIcon Kind="TuneVariant" Foreground="#6750A4" Width="25" Height="25" />
                        <TextBlock Text="{Binding ConfigCount}" FontSize="34" FontWeight="SemiBold" Margin="0,16,0,2" />
                        <TextBlock Text="测量配置" Foreground="#6B7280" /></StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="7,0" Padding="22">
                    <StackPanel><materialDesign:PackIcon Kind="MapMarkerPath" Foreground="#006A6A" Width="25" Height="25" />
                        <TextBlock Text="{Binding PathCount}" FontSize="34" FontWeight="SemiBold" Margin="0,16,0,2" />
                        <TextBlock Text="运动路径" Foreground="#6B7280" /></StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Margin="14,0,0,0" Padding="22">
                    <StackPanel><materialDesign:PackIcon Kind="FileChartOutline" Foreground="#A23B3B" Width="25" Height="25" />
                        <TextBlock Text="{Binding ReportCount}" FontSize="34" FontWeight="SemiBold" Margin="0,16,0,2" />
                        <TextBlock Text="测量报告" Foreground="#6B7280" /></StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <materialDesign:Card Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="硬件连接" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#6B7280" Margin="0,6,0,18" />
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="14,9" Margin="0,0,12,0">
                                <TextBlock Text="● 测量仪器已连接" Foreground="#247A3D" />
                            </Border>
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="14,9">
                                <TextBlock Text="● 运动平台已连接" Foreground="#247A3D" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding LoadCommand}" Content="刷新状态"
                            Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Top" />
                </Grid>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
